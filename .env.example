# ================================================================
#  DreamShop — Environment Variables
#  Rename this file to .env  |  Never commit .env to Git
# ================================================================

# ── Database ─────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/shopping_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=admin123

# ── Redis ────────────────────────────────────────────────────
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────
# Must be at least 32 characters — change this before going live
JWT_SECRET=MySuperSecureJwtSecretKeyThatIsAtLeast32CharactersLong12345

# ── Stripe ───────────────────────────────────────────────────
# Use sk_test_... for dev  |  sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
# ── Spring Profile ───────────────────────────────────────────
# dev = uses application-dev.yml (local Postgres + Redis)
# prod = uses application-prod.yml (all values from this file)
SPRING_PROFILES_ACTIVE=dev
